{
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "context-mode@context-mode": true
  },
  "extraKnownMarketplaces": {
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      },
      "autoUpdate": true
    }
  },
  "permissions": {
    "allow": [
      "Read(~/Nextcloud/secondbrain/**)"
    ]
  }
}
